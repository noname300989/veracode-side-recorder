{
  "manifest_version": 3,
  "name": "Veracode SIDE Recorder",
  "version": "1.0.0",
  "description": "Records browser interactions and exports Veracode-safe Selenium IDE SIDE files.",
  "permissions": [
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Veracode SIDE Recorder",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/veracode-side.js",
        "shared/recorder-dom.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
